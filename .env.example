# ══════════════════════════════════════════════════════════════
#  Steel Supply Chain — Environment Configuration
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Steel PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=steel_admin
POSTGRES_PASSWORD=your_postgres_password_here
# Full URL assembled automatically by portal; set this OR the parts above
DATABASE_URL=postgresql://steel_admin:your_postgres_password_here@steel-postgres:5432/steel_db

# ── Airflow PostgreSQL (metadata DB) ─────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASS=your_airflow_db_password_here

# ── Airflow Admin Credentials ─────────────────────────────────
# Used by airflow-init and manager.py API calls
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=your_strong_airflow_password_here

# ── Airflow Security ──────────────────────────────────────────
# Generate your own key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here

# ── manager.py → Airflow REST API ────────────────────────────
# Running manager.py from HOST machine (outside Docker):
AIRFLOW_BASE_URL=http://localhost:8089/api/v1
# Running manager.py INSIDE Docker network (e.g. inside spark-master):
# AIRFLOW_BASE_URL=http://airflow-webserver:8080/api/v1

# ── Portal Security ───────────────────────────────────────────
# REQUIRED — portal aborts at startup if missing or < 32 chars
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(64))"
PORTAL_SECRET_KEY=your_64_char_random_secret_here

# ── Portal Admin (fallback user when DB is unavailable) ───────
PORTAL_USER=admin
PORTAL_PASS=your_strong_portal_admin_password_here

# ── Steel Price Anomaly Detection ────────────────────────────
# Baseline EGP/ton used for streaming price-spike alerts
STEEL_PRICE_BASELINE=42000.0

# ── Energy Cost Fallback Defaults ────────────────────────────
# Used in silver_etl when live market prices are unavailable
ELECTRICITY_COST_EGP=3.5
USD_EGP_RATE=50.0
