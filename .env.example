# ══════════════════════════════════════════════════════════════
#  Steel Supply Chain — Environment Configuration
#  Copy this file to .env and fill in your values:
#      cp .env.example .env
# ══════════════════════════════════════════════════════════════

# ── Steel PostgreSQL ──────────────────────────────────────────
POSTGRES_USER=steel_admin
POSTGRES_PASSWORD=your_postgres_password_here

# ── Airflow PostgreSQL (metadata DB) ─────────────────────────
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASS=your_airflow_db_password_here

# ── Airflow Admin Credentials ─────────────────────────────────
# Used by airflow-init and manager.py API calls
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=your_airflow_admin_password_here

# ── Airflow Security ──────────────────────────────────────────
# Generate your own key with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=your_generated_fernet_key_here

# ── manager.py → Airflow REST API ────────────────────────────
# Running manager.py from HOST machine (outside Docker):
AIRFLOW_BASE_URL=http://localhost:8089/api/v1
# Running manager.py INSIDE Docker network (e.g. inside spark-master):
# AIRFLOW_BASE_URL=http://airflow-webserver:8080/api/v1
